# Upload files (jangan di-commit ke Git)
assets/images/uploads/*
!assets/images/uploads/.gitkeep

# Environment lokal (jangan commit jika berisi password production)
# config/env.php sudah disertakan di repo dengan nilai default XAMPP
# Jika kamu mengubah password/kredensial, tambahkan kembali baris ini:
# config/env.php
.env

# Installer lock (hapus setelah instalasi)
install.lock

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# PHP error log
*.log
error_log
